<div class="w-full max-w-6xl mx-auto px-4 py-6">
  <h1 class="text-2xl font-bold mb-4">Teams</h1>

  <div class="bg-white rounded-xl shadow p-4 overflow-x-auto">
    <table class="min-w-full text-left border-collapse">
      <thead>
        <tr class="border-b">
          <th class="py-2 pr-4">Team</th>
          <th class="py-2 pr-4">AP</th>
          <% @rooms.each_with_index do |_room, index| %>
            <th class="py-2 pr-4">Room <%= index + 1 %></th>
          <% end %>
          <th class="py-2 pr-4">Detail</th>
        </tr>
      </thead>
      <tbody>
        <% @teams.each do |team| %>
          <% cleared_room_ids = team.clear_room_histories.map(&:room_id) %>
          <tr class="border-b last:border-0">
            <td class="py-2 pr-4 font-medium"><%= team.name %></td>
            <td class="py-2 pr-4"><%= team.current_points %></td>
            <% @rooms.each do |room| %>
              <td class="py-2 pr-4"><%= cleared_room_ids.include?(room.id) ? "✓" : "-" %></td>
            <% end %>
            <td class="py-2 pr-4">
              <% if current_user.team_id == team.id %>
                <%= link_to "Detail", team_path(team), class: "text-blue-600 hover:underline" %>
              <% else %>
                <span class="text-gray-400">-</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
