<div class="w-full max-w-4xl mx-auto px-4 py-6">
  <h1 class="text-2xl font-bold mb-4">Team Detail</h1>

  <div class="bg-white rounded-xl shadow p-4 space-y-6">
    <div>
      <h2 class="font-semibold mb-2">Team information</h2>
      <p><span class="font-medium">Team:</span> <%= @team.name %></p>
      <p><span class="font-medium">AP:</span> <%= @team.current_points %></p>
    </div>

    <div>
      <h2 class="font-semibold mb-2">Cleared rooms</h2>
      <% cleared_room_ids = @team.clear_room_histories.map(&:room_id) %>
      <table class="min-w-full border-collapse">
        <thead>
          <tr class="border-b">
            <% @rooms.each_with_index do |_room, index| %>
              <th class="py-2 pr-4 text-left">Room <%= index + 1 %></th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <tr>
            <% @rooms.each do |room| %>
              <td class="py-2 pr-4"><%= cleared_room_ids.include?(room.id) ? "✓" : "-" %></td>
            <% end %>
          </tr>
        </tbody>
      </table>
    </div>

    <div>
      <h2 class="font-semibold mb-2">Members</h2>
      <table class="min-w-full border-collapse">
        <thead>
          <tr class="border-b">
            <th class="py-2 pr-4 text-left">Name</th>
            <th class="py-2 pr-4 text-left">Email</th>
          </tr>
        </thead>
        <tbody>
          <% @members.each do |member| %>
            <% derived_name = member.email.to_s.split("@").first %>
            <tr class="border-b last:border-0">
              <td class="py-2 pr-4"><%= member.name.presence || derived_name.presence || "-" %></td>
              <td class="py-2 pr-4"><%= member.email.presence || "-" %></td>
            </tr>
          <% end %>
          <% if @members.empty? %>
            <tr>
              <td colspan="2" class="py-2 text-gray-500">No members yet</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
