<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Sun*ESC</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body class="bg-gray-50 min-h-screen flex flex-col select-none">

    <header class="bg-white shadow p-4 flex justify-between items-center">
      <%= link_to root_path do %>
        <h1 class="text-xl font-semibold text-gray-800">Sun*ESC</h1>
      <% end %>

      <% if current_user %>
        <div class="flex items-center space-x-3">
          <span class="text-gray-700 font-medium"><%= current_user.id.to_s.first(8) %>...</span>
          <%= link_to 'Logout', logout_path, class: "bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600 transition" %>
        </div>
      <% else %>
        <%= link_to "Login with Sun*Email", "/auth/google_oauth2", class: "bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600 transition" %>
      <% end %>
    </header>
    <% if notice.present? || alert.present? %>
      <div class="w-full max-w-4xl mx-auto px-4 mt-4">
        <% if notice.present? %>
          <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative" role="alert">
            <span class="block sm:inline"><%= notice %></span>
          </div>
        <% end %>
        <% if alert.present? %>
          <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative" role="alert">
            <span class="block sm:inline"><%= alert %></span>
          </div>
        <% end %>
      </div>
    <% end %>
    <main class="flex-grow flex items-center justify-center text-gray-700 text-lg">
      <%= yield %>
    </main>

  </body>
</html>
